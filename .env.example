# Copy this file to .env and fill in real values. Never commit .env.

# --- Supabase (Postgres + Auth + Storage) ---
# Project Settings > Database > Connection string. Prisma 7's config
# (prisma.config.ts) only takes one URL, currently set to DATABASE_URL —
# revisit pooled-vs-direct split in Phase 1 once migrations are actually run.
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres"

# Project Settings > API
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# --- Auth providers (configured in Supabase Auth > Providers) ---
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# --- Resend (transactional email) ---
# https://resend.com/api-keys
RESEND_API_KEY=""
RESEND_FROM_EMAIL="hello@automatewithjohn.com"

# --- reCAPTCHA v3 (spam protection on contact/consultation forms) ---
# https://www.google.com/recaptcha/admin/create — register a v3 site
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=""
RECAPTCHA_SECRET_KEY=""

# --- Google Analytics 4 ---
# https://analytics.google.com > Admin > Data Streams > your web stream
NEXT_PUBLIC_GA4_MEASUREMENT_ID=""

# --- Microsoft Clarity ---
# https://clarity.microsoft.com > your project > Settings > Overview
NEXT_PUBLIC_CLARITY_PROJECT_ID=""

# --- Google Search Console ---
# https://search.google.com/search-console > Settings > Ownership verification
# > HTML tag method — copy just the content="..." token, not the full tag.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=""

# --- OpenAI (Phase 11 chatbot) ---
# https://platform.openai.com/api-keys
OPENAI_API_KEY=""

# --- App ---
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
