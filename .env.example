# Copy this file to .env and fill in real values. Never commit .env.

# --- Supabase (Postgres + Auth + Storage) ---
# Project Settings > Database > Connection string. Prisma 7's config
# (prisma.config.ts) only takes one URL, currently set to DATABASE_URL —
# revisit pooled-vs-direct split in Phase 1 once migrations are actually run.
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres"

# Project Settings > API
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# --- Auth providers (configured in Supabase Auth > Providers) ---
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# --- Resend (transactional email) ---
# https://resend.com/api-keys
RESEND_API_KEY=""
RESEND_FROM_EMAIL="hello@automatewithjohn.com"

# --- Razorpay (payments) ---
# https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# --- Google Analytics 4 ---
NEXT_PUBLIC_GA4_MEASUREMENT_ID=""

# --- Microsoft Clarity ---
NEXT_PUBLIC_CLARITY_PROJECT_ID=""

# --- OpenAI (Phase 11 chatbot) ---
OPENAI_API_KEY=""

# --- App ---
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
